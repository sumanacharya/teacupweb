# Contact form — SMTP credentials
# Set these in Vercel project settings (Settings > Environment Variables)
# For local dev, copy this file to .env and fill in your values

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Email address that receives contact form submissions
CONTACT_TO=contact@teacupdigital.com.au
