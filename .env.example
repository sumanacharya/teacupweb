# Copy to `.env` on the server (never commit secrets).

# Recipient inbox for contact form submissions
CONTACT_MAIL_TO=contact@teacupdigital.com.au

# SMTP — required for `/api/contact` (e.g. transactional provider or your mail server)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Must be authorised by your SMTP provider (often matches SMTP_USER)
SMTP_FROM=
